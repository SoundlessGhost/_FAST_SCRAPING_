# Resend API key (https://resend.com/api-keys)
# Required for the contact form (POST /api/contact)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# From address. Must be on a domain you have verified in Resend.
# Example after fastscraping.com is verified:
#   CONTACT_FROM="Fastscraping <notes@fastscraping.com>"
CONTACT_FROM="Fastscraping <notes@fastscraping.com>"

# Recipient. Defaults to khalid@fastscraping.com.
CONTACT_TO=khalid@fastscraping.com

# ---- Client usage dashboard (/dashboard) ----
# Shopee usage backend. Called server-side only; never exposed to the browser.
SCRAPE_API_BASE=http://86.48.2.59:8040

# Encryption key for the dashboard session cookie (iron-session).
# MUST be at least 32 characters. Generate a strong random value in production,
# e.g.  openssl rand -base64 32
SESSION_SECRET=change_me_to_a_long_random_string_min_32_chars
