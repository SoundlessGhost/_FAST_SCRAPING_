# Resend API key (https://resend.com/api-keys)
# Required for the contact form (POST /api/contact)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# From address. Until fastscraping.com is verified in Resend, use the shared
# onboarding sender (delivers only to your Resend account email).
#   After verifying the domain: CONTACT_FROM="Fastscraping <notes@fastscraping.com>"
CONTACT_FROM="Fastscraping <onboarding@resend.dev>"

# Recipient. Until the domain is verified this must be your Resend account email.
CONTACT_TO=khalid@fastscraping.com

# ---- Client usage dashboard (/dashboard) ----
SCRAPE_API_BASE=http://86.48.2.59:8040
# iron-session cookie encryption key — at least 32 chars. e.g. openssl rand -base64 32
SESSION_SECRET=change_me_to_a_long_random_string_min_32_chars
